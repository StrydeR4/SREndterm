{
  "title": "MicroShop Overview",
  "uid": "microshop",
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Login Attempts",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(auth_login_total)", "legendFormat": "Logins"}],
      "datasource": "Prometheus"
    },
    {
      "id": 2, "type": "stat", "title": "Total Orders",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(orders_total)", "legendFormat": "Orders"}],
      "datasource": "Prometheus"
    },
    {
      "id": 3, "type": "stat", "title": "Order Errors",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(order_errors_total)", "legendFormat": "Errors"}],
      "datasource": "Prometheus"
    },
    {
      "id": 4, "type": "timeseries", "title": "Product Request Rate",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "rate(product_requests_total[1m])", "legendFormat": "{{endpoint}}"}],
      "datasource": "Prometheus"
    },
    {
      "id": 5, "type": "timeseries", "title": "Order Errors Over Time",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "rate(order_errors_total[1m])", "legendFormat": "Errors/s"}],
      "datasource": "Prometheus"
    }
  ],
  "schemaVersion": 38,
  "time": {"from": "now-30m", "to": "now"}
}
